<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/BG_color"
    tools:context=".Category_Page">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="2dp"
            android:layout_marginStart="32dp"
            android:orientation="vertical">



                <TextView
                    android:id="@+id/CategoryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/f"
                    android:textColor="?attr/AccentColor"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:layout_gravity="top|start"
                    tools:text="Marvel Studios" />

                <TextView
                    android:id="@+id/CategorySubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/e"
                    android:textColor="?attr/FG_color"
                    android:textSize="12sp"
                    android:alpha="0.7"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:layout_gravity="top|start"
                    tools:text="Movies &amp; TV titles" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/CategoryMoviesRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none"
                        tools:ignore="RtlSymmetry" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/CategoryTvRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:scrollbars="none"
                        android:visibility="gone"
                        tools:ignore="RtlSymmetry" />
        </LinearLayout>



        <LinearLayout
            android:id="@+id/categoryButtonColumn"
            android:layout_width="30dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical|start"
            android:orientation="vertical"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/CategoryMoviesButtonLayout"
                android:layout_width="match_parent"
                android:layout_height="70sp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/right_rounded"
                android:gravity="center"
                android:focusable="true"
                android:focusableInTouchMode="true">

                <TextView
                    android:id="@+id/CategoryMoviesButtonText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mv"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/a"
                    android:textColor="?attr/FG_color"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/CategoryTvButtonLayout"
                android:layout_width="match_parent"
                android:layout_height="70sp"
                android:background="@drawable/right_rounded"
                android:gravity="center"
                android:focusable="true"
                android:focusableInTouchMode="true">

                <TextView
                    android:id="@+id/CategoryTvButtonText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tv"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/a"
                    android:textColor="?attr/FG_color"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

        </LinearLayout>

        <include layout="@layout/laod_animation" />
        <include layout="@layout/side_bar" android:visibility="gone" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>