<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/BG_color"
    tools:context=".Profile_Page">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@raw/test2"
        tools:ignore="ContentDescription" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/mainBox"
        android:layout_margin="0dp"
        android:layout_gravity="center"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        app:cardBackgroundColor="?attr/transparentEffect"
        app:cardCornerRadius="0dp">



        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            tools:ignore="RtlSymmetry"
            android:background="?attr/transparentEffect"
            android:nextFocusLeft="@id/btnProfile">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/transparentEffect"
                android:orientation="horizontal"
                tools:ignore="RtlSymmetry">


                <LinearLayout
                    android:layout_width="300dp"
                    android:layout_height="match_parent"
                    android:baselineAligned="false"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:background="?attr/transparentEffect"
                    tools:ignore="DisableBaselineAlignment">

                    <androidx.cardview.widget.CardView
                        android:layout_width="180dp"
                        android:layout_height="180dp"
                        android:layout_gravity="center_horizontal"
                        app:cardBackgroundColor="?attr/transparentEffect"
                        android:layout_margin="14dp"
                        android:elevation="4dp"
                        app:cardCornerRadius="50dp">
                        <ImageView
                            android:id="@+id/ProfileImg"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:importantForAccessibility="no"
                          />

                    </androidx.cardview.widget.CardView>
                    
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" 
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="130dp"
                            android:layout_height="80dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/rounded_background"
                            android:padding="10dp"
                            android:layout_margin="4dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/moviesWatched"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="?attr/AccentColor"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Movies Watched"
                                android:textColor="?attr/FG_color"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText,SmallSp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="130dp"
                            android:layout_height="80dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/rounded_background"
                            android:padding="15dp"
                            android:layout_margin="4dp"
                            >

                            <TextView
                                android:id="@+id/seriesWatched"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="?attr/AccentColor"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Episodes Watched"
                                android:textColor="?attr/FG_color"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText,SmallSp" />

                        </LinearLayout>
                        
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="130dp"
                            android:layout_height="80dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/rounded_background"
                            android:padding="10dp"
                            android:layout_margin="4dp"
                            android:layout_marginEnd="10dp">

                            <TextView
                                android:id="@+id/animeWatched"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="?attr/AccentColor"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Anime Watched"
                                android:textColor="?attr/FG_color"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText,SmallSp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="130dp"
                            android:layout_height="80dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/rounded_background"
                            android:padding="15dp"
                            android:layout_margin="4dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                >


                                <TextView
                                    android:id="@+id/SubscriptionLeft"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@android:color/holo_green_light"
                                    android:textSize="17sp"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Days Left"
                                    android:textColor="?attr/FG_color"
                                    android:textSize="12sp"
                                    android:textStyle="italic"
                                    android:paddingStart="5dp"
                                    android:alpha="0.5"
                                    tools:ignore="HardcodedText" />

                            </LinearLayout>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TIER ACTIVATION"
                                android:textColor="?attr/FG_color"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:textSize="10sp"
                                android:layout_marginTop="4dp"
                                tools:ignore="HardcodedText,SmallSp" />
                        </LinearLayout>
                        

                        
                        
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/logoutBtn"
                        android:layout_width="wrap_content"
                        android:background="@drawable/setting_item_background"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:layout_margin="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="14dp"
                            android:textColor="?attr/FG_color"
                            android:fontFamily="@font/f"
                            android:text="Logout"
                            tools:ignore="HardcodedText,SpUsage" />
                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:src="@drawable/ic_logout"
                            android:layout_marginStart="14dp"
                            app:tint="?attr/FG_color"/>
                    </LinearLayout>

                    

                    

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

              
                    <LinearLayout
                        android:id="@+id/themeSetting"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:clickable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_palette"
                            android:contentDescription="App Theme"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="App Theme"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/themeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dark"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/versionInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:clickable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_info"
                            android:contentDescription="App Info"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="App Version"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:id="@+id/appVersion"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.0.0"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Clear Cache -->
                    <LinearLayout
                        android:id="@+id/clearCache"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:clickable="true"
                        android:focusableInTouchMode="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_delete"
                            android:contentDescription="Clear Cache"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Clear Cache"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Free up storage space"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Check for Updates -->
                    <LinearLayout
                        android:id="@+id/checkUpdates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:clickable="true"
                        android:focusableInTouchMode="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_update"
                            android:contentDescription="Check for Updates"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Updates"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Check and update up"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Restart App -->
                    <LinearLayout
                        android:id="@+id/restartApp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:clickable="true"
                        android:focusableInTouchMode="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_restart"
                            android:contentDescription="Restart App"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Restart App"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Restart the application"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Terms and Conditions -->
                    <LinearLayout
                        android:id="@+id/termsAndConditions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="15dp"
                        android:background="@drawable/setting_item_background"
                        android:layout_marginBottom="8dp"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:clickable="true">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_terms"
                            android:contentDescription="Terms and Conditions"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Terms and Conditions"
                                android:textColor="?attr/FG_color"
                                android:textSize="16sp"
                                tools:ignore="HardcodedText" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View terms of service and privacy policy"
                                android:textColor="?attr/FG_color"
                                android:textSize="12sp"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />

                        </LinearLayout>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:contentDescription="Navigate"
                            app:tint="?attr/FG_color"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <include layout="@layout/laod_animation"/>

    </androidx.cardview.widget.CardView>

    <include layout="@layout/side_bar"/>

</androidx.constraintlayout.widget.ConstraintLayout>