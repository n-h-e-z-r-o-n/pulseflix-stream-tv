<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".Instraction">

    <ImageView
        android:id="@+id/pageBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@raw/test2"
        />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#B3000000"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="15dp"
        android:paddingTop="35dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ONYX"
                android:textSize="65sp"
                android:layout_gravity="center_horizontal"
                android:textColor="?attr/FG_color"
                tools:ignore="HardcodedText"
                android:shadowColor="?attr/AccentColor"
                android:shadowDx="5"
                android:shadowDy="6"
                android:shadowRadius="4"
                android:fontFamily="@font/j"
                android:visibility="visible" />

            <TextView
                android:id="@+id/textViewStep1Header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Stream Movies, Tv and Anime"
                android:fontFamily="@font/e"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:textColor="#FFC107"
                android:textSize="30sp"
                android:layout_marginTop="6dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ad-ree"
                android:fontFamily="@font/e"
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:textColor="?attr/FG_color"
                android:textSize="30sp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:elevation="8dp">

                <!-- Outer Frame (TV body) -->
                <androidx.cardview.widget.CardView
                    android:layout_width="220dp"
                    android:layout_height="130dp"
                    android:elevation="6dp"
                    app:cardCornerRadius="16dp"
                    android:layout_gravity="center">

                    <!-- TV Screen -->
                    <ImageView
                        android:id="@+id/tvScreen"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:adjustViewBounds="true"
                        android:src="@raw/test"
                        android:foreground="@drawable/tv_frame_background"
                        android:scaleType="fitXY"
                        tools:ignore="UnusedAttribute" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download Instraction "
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="@font/f"
                android:layout_marginTop="8dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 1.Open the web browser on your TV and go to the following short address:"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:layout_marginTop="8dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                android:layout_gravity="center_horizontal"
                app:cardBackgroundColor="?attr/AccentColor"
                android:elevation="0dp"
                >
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="250dp"
                        android:layout_height="70dp"
                        android:scaleType="centerCrop"
                        android:src="@raw/gold"
                        />

                    <TextView
                        android:id="@+id/textViewUrl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="bit.ly/43L6WYr"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="28sp"
                        android:layout_gravity="center"
                        style="@style/Widget.AppCompat.TextView"
                        tools:ignore="HardcodedText" />


                </FrameLayout>

            </androidx.cardview.widget.CardView>



            <TextView
                android:id="@+id/textViewStep1Footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This will download the installation file (app-release.apk or app-release.bin)."
                android:textColor="@android:color/white"
                android:textSize="9sp"
                android:alpha="0.8"
                android:layout_marginTop="6dp"
                android:layout_gravity="center_horizontal"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />


            <TextView
                android:id="@+id/textViewStep2Body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='2. If you don&apos;t  know how to install, On your android  tv go to  Google Play Store on your TV and install "File Manager+".'
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:layout_marginTop="8dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/textViewStep2Body2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text='3. Open your file manager, navigate to the "Download" folder, and find the file named app-release.apk or app-release.bin.'
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/textViewStep2Body3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3. Select the file and install it using the Package Installer. You may need to grant permission to install from unknown sources."
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:layout_marginTop="16dp"
                style="@style/Widget.AppCompat.TextView"
                tools:ignore="HardcodedText" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
