<!-- res/layout/item_grid.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="289dp"
    android:layout_height="170dp"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="2dp"
    card_view:cardBackgroundColor="?attr/BG_color_up"
    android:foreground="@drawable/card_focus"
    android:id="@+id/itemGrid2">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <ImageView
            android:id="@+id/itemImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:scaleType="fitXY"
            />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">


        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="17dp"
            app:cardCornerRadius="4dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:layout_marginStart="5dp"
            android:layout_marginTop="10dp">
            <TextView
                android:id="@+id/itemText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="?attr/BG_color"
                android:ellipsize="end"
                android:text="2015"
                android:gravity="center"
                android:paddingHorizontal="4dp"
                android:rotationX="0"
                android:fontFamily="@font/p"
                android:singleLine="true"
                android:textColor="?attr/FG_color"
                android:textSize="12sp"
                tools:ignore="HardcodedText,SmallSp" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="15dp"
            android:layout_marginStart="5dp"
            android:layout_marginTop="10dp"
            >
            <TextView
                android:id="@+id/showType"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:ellipsize="end"
                android:text="movie"
                android:fontFamily="@font/a"
                android:gravity="center"
                android:padding="1dp"
                android:rotationX="0"
                android:singleLine="true"
                android:textColor="?attr/FG_color"
                android:textSize="12sp"
                tools:ignore="HardcodedText,SmallSp" />


        </LinearLayout>

            <TextView
                android:id="@+id/showRating"
                android:layout_width="wrap_content"
                android:layout_height="15dp"
                android:layout_marginStart="5dp"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="7.5 imdb"
                android:textColor="?attr/FG_color"
                android:textSize="12sp"
                android:fontFamily="@font/p"
                tools:ignore="HardcodedText,SmallSp"
                android:paddingEnd="5dp"
                android:paddingStart="5dp"
                />

            <TextView
                android:id="@+id/showRS"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp"
                android:layout_height="15dp"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="⏱145 min"
                android:textColor="?attr/FG_color"
                android:textSize="7sp"
                android:fontFamily="@font/e"
                tools:ignore="HardcodedText,SmallSp"
                android:paddingEnd="5dp"
                android:paddingStart="5dp"
                android:gravity="center|end"
                android:visibility="gone"
                />
        </LinearLayout>







        <!-- 🔥 Focus Overlay -->
        <LinearLayout
            android:id="@+id/focusOverlay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:gravity="bottom"
            android:visibility="gone"
            android:paddingBottom="2dp"
            android:paddingTop="14dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            >
        </LinearLayout>

        <TextView
            android:id="@+id/showTitle"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@android:color/transparent"
            android:ellipsize="end"
            android:text="Tekdss"
            android:fontFamily="@font/o"
            android:padding="8dp"
            android:rotationX="0"
            android:singleLine="false"
            android:maxLines="3"
            android:shadowColor="#80000000"
            android:shadowDx="2"
            android:shadowDy="4"
            android:shadowRadius="4"
            android:textColor="@android:color/white"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/itemLogo"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:maxHeight="200dp"
            android:scaleType="fitXY"
            tools:ignore="ContentDescription"
            android:layout_marginBottom="10dp"
            android:layout_marginStart="4dp"
            android:layout_gravity="bottom"/>

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

    </LinearLayout>

</androidx.cardview.widget.CardView>




