<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true"
    tools:context=".Watch_Page"
    android:background="?attr/BG_color">



    <ScrollView
        android:id="@+id/mainr"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="?attr/BG_color">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">




            <FrameLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/widget_1">

                <!-- Backdrop image -->
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="right"
                    tools:ignore="RtlHardcoded">

                    <!-- Backdrop image -->
                    <ImageView
                        android:id="@+id/backdropImageView"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@raw/test3"
                        tools:ignore="ContentDescription" />

                    <!-- Gradient overlay left-->
                    <LinearLayout
                        android:layout_width="300dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/overlay_left_gradient"
                        android:alpha="1"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_gravity="bottom"
                        android:alpha="1"
                        android:background="@drawable/overlay_bottom_gradient" />

                </FrameLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center"
                    tools:ignore="RtlSymmetry">



                    <ImageView
                        android:id="@+id/posterImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="fitXY"
                        android:visibility="gone"
                        android:background="@android:color/transparent"
                        tools:ignore="ContentDescription" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingTop="16dp"
                            tools:ignore="RtlSymmetry">

                        <ImageView
                            android:id="@+id/cShowLogo"
                            android:layout_width="300dp"
                            android:layout_height="wrap_content"
                            android:maxHeight="200dp"
                            android:scaleType="fitXY"
                            tools:ignore="ContentDescription" />





                        <TextView
                            android:id="@+id/title_widget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="3"
                            android:maxWidth="400dp"
                            android:text="Movie Title"
                            android:textColor="?attr/FG_color"
                            android:fontFamily="@font/p"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText"
                            android:shadowColor="#80000000"
                            android:shadowDx="5"
                            android:shadowDy="6"
                            android:shadowRadius="4"/>




                        <TextView
                            android:id="@+id/Production_widget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:alpha="0.8"
                            android:text="- Marvel    - DC   - action"
                            android:textColor="?attr/FG_color"
                            android:textSize="9sp"
                            android:textStyle="italic"
                            android:visibility="gone"
                            tools:ignore="HardcodedText,SmallSp" />

<!-- ========================================================================================    -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity=""
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingEnd="0dp" >



                            <!-- Rating -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="start"
                                android:orientation="horizontal"

                                >

                                <androidx.cardview.widget.CardView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    app:cardCornerRadius="3dp"
                                    android:text="IMDB"

                                    android:textSize="11sp"
                                    app:cardBackgroundColor="#DAA520"
                                    tools:ignore="HardcodedText"
                                    android:textStyle="bold">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="IMDb"
                                        android:paddingVertical="2dp"
                                        android:paddingHorizontal="5dp"
                                        android:textColor="#000000"
                                        android:textStyle="bold"
                                        android:textSize="11sp"
                                        android:fontFamily="@font/p"
                                        tools:ignore="HardcodedText" />

                                </androidx.cardview.widget.CardView>
                                <TextView
                                    android:id="@+id/Rating_widget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="2dp"
                                    android:text="8.5"
                                    android:layout_gravity="center"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:background="#FFFFFF"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:alpha="0.5"/>

                            <TextView
                                android:id="@+id/season_C"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:textColor="#FFFFFF"
                                android:fontFamily="@font/q"
                                android:textSize="11sp"
                                tools:ignore="HardcodedText,SmallSp"/>

                            <View
                                android:layout_width="1dp"
                                android:background="#FFFFFF"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:alpha="0.5"/>

                            <!-- Runtime -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="start"
                                android:orientation="horizontal"
                                android:paddingEnd="0dp"
                                >

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏱ "
                                    android:textColor="#FFFFFF"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText" />
                                <TextView
                                    android:id="@+id/Runtime_widget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2h 3min"
                                    android:textColor="#FFFFFF"
                                    android:textStyle="bold"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:background="#FFFFFF"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:alpha="0.5"/>

                            <!-- Year -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="start"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/year_widget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:text="2025"
                                    android:textColor="?attr/FG_color"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText"
                                    android:textStyle="bold"    />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:background="#FFFFFF"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:alpha="0.5"/>

                            <!-- Pg -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="start"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PG "
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/d"
                                    android:textStyle="bold"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText" />
                                <TextView
                                    android:id="@+id/PG_widget"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="13"
                                    android:textColor="#FFFFFF"
                                    android:fontFamily="@font/p"
                                    android:textStyle="bold"
                                    android:textSize="11sp"
                                    tools:ignore="HardcodedText" />
                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:background="#FFFFFF"
                                android:layout_height="15dp"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="5dp"
                                android:alpha="0.5"/>




                                <ImageView
                                    android:layout_marginStart="10dp"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:src="@drawable/ic_hdr"
                                    app:tint="?attr/FG_color"
                                    android:textSize="11sp"
                                    android:alpha="0.7"/>

                                <ImageView
                                    android:layout_marginStart="0dp"
                                    android:layout_width="24dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_caption"
                                    app:tint="?attr/FG_color"
                                    android:textSize="11sp"
                                    android:alpha="0.7"/>


                        </LinearLayout>

                        <!-- VoteCount -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="start"
                            android:layout_marginBottom="10dp"
                            android:orientation="horizontal"
                            android:layout_marginEnd="15dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="★★☆ "
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:id="@+id/VoteCount_widget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="342323"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:fontFamily="@font/n"
                                android:textSize="14sp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/Genres_widget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Science fiction     drama   - action"
                            android:textColor="?attr/FG_color"
                            android:textSize="11sp"
                            tools:ignore="HardcodedText"
                            android:fontFamily="@font/n"
                            android:textStyle="bold"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:gravity="start"
                            android:orientation="horizontal"
                            android:padding="5dp"
                            android:paddingEnd="0dp" >

                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="460dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:gravity="start"
                            android:maxHeight="145dp"
                            android:orientation="horizontal"
                            android:paddingEnd="0dp"
                            android:layout_marginBottom="9dp">

                            <TextView
                                android:id="@+id/overview_widget"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:ellipsize="end"
                                android:maxLines="4"
                                android:singleLine="false"
                                android:text="An assassin, trained in the ways of the Ruska Roma, embarks on a quest for vengeance following the death of her father."
                                android:textColor="?attr/FG_color"
                                android:textSize="13sp"
                                android:fontFamily="@font/p"
                                tools:ignore="HardcodedText"
                                />

                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingEnd="0dp">

                            <!-- This is our custom expanding button -->
                            <LinearLayout
                                android:id="@+id/watchNowButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:background="@drawable/watch_button"
                                android:focusableInTouchMode="true"
                                android:focusable="true"
                                android:clickable="true"
                                android:paddingHorizontal="14dp"
                                android:nextFocusLeft="@+id/serverButton"
                                android:nextFocusRight="@+id/TrailerButton"
                                android:elevation="2dp"
                                android:layout_marginEnd="10dp">


                            <ImageButton
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/ic_play"
                                app:tint="?attr/FG_color"
                                android:textAllCaps="false"
                                tools:ignore="ContentDescription,UnusedAttribute" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Play"
                                android:textSize="15sp"
                                android:fontFamily="@font/o"
                                android:textColor="?attr/FG_color"
                                android:textStyle="bold"
                                tools:ignore="HardcodedText" />

                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/TrailerButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:background="@drawable/watch_button"
                                android:focusableInTouchMode="true"
                                android:focusable="true"
                                android:clickable="true"
                                android:paddingHorizontal="14dp"
                                android:nextFocusLeft="@+id/watchNowButton"
                                android:nextFocusRight="@+id/favoriteButton"
                                android:elevation="2dp"
                                android:visibility="gone">

                                <ImageButton
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:layout_marginStart="12dp"
                                android:background="@drawable/tv_button_selector"
                                android:src="@drawable/ic_trailer"
                                app:tint="?attr/AccentColor"                                android:textSize="14sp"
                                android:textAllCaps="false"
                                android:elevation="2dp"
                                tools:ignore="ContentDescription,UnusedAttribute"
/>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/favoriteButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:background="@drawable/watch_button"
                                android:focusableInTouchMode="true"
                                android:focusable="true"
                                android:clickable="true"
                                android:layout_marginEnd="10dp"
                                android:paddingHorizontal="14dp"
                                android:nextFocusLeft="@+id/TrailerButton"
                                android:nextFocusRight="@+id/serverButton"
                                android:elevation="2dp" >



                                <ImageButton
                                    android:id="@+id/favoriteButtonImg"
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:src="@drawable/ic_addfave"
                                    app:tint="?attr/FG_color"
                                    android:background="@android:color/transparent"
                                    android:textColor="?attr/FG_color"
                                    android:textAllCaps="false"
                                    android:tooltipText="Add to Favorites"
                                    tools:ignore="UnusedAttribute" />

                                <TextView
                                    android:id="@+id/favoriteButtonText"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="favorite"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/o"
                                    android:textColor="?attr/FG_color"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText" />

                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/serverButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:background="@drawable/watch_button"
                                android:focusableInTouchMode="true"
                                android:focusable="true"
                                android:clickable="true"
                                android:paddingHorizontal="14dp"
                                android:nextFocusLeft="@+id/favoriteButton"
                                android:nextFocusRight="@+id/watchNowButton"
                                android:elevation="2dp"
                                android:layout_marginEnd="10dp">

                                <ImageButton
                                    android:layout_width="34dp"
                                    android:layout_height="34dp"
                                    android:background="@android:color/transparent"
                                    android:src="@drawable/ic_server"
                                    app:tint="?attr/FG_color"
                                    android:textAllCaps="false"
                                    tools:ignore="ContentDescription" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Server"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/o"
                                    android:textColor="?attr/FG_color"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText" />

                            </LinearLayout>

                        </LinearLayout>



                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/Season_widget"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:orientation="vertical"
                        android:visibility="gone">


                        <!-- ✅ Season Selector goes here -->
                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:scrollbars="none"
                            android:clipToPadding="false"
                            android:paddingVertical="1dp">

                            <LinearLayout
                                android:id="@+id/season_selector_container"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <Button
                                    android:id="@+id/season_1_btn"
                                    android:layout_width="120dp"
                                    android:layout_height="48dp"
                                    android:layout_marginEnd="8dp"
                                    android:text="Season"

                                    android:textColor="?attr/FG_color"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/p"
                                    android:background="@drawable/season_selector"
                                    android:focusable="true"
                                    android:focusableInTouchMode="true"
                                    android:stateListAnimator="@null"
                                    android:textAllCaps="false"
                                    tools:ignore="HardcodedText,TooDeepLayout" />

                                <!-- Add more season buttons dynamically or here -->

                            </LinearLayout>
                        </HorizontalScrollView>


                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/AccentColor"
                            android:alpha="0.3" />

                        <include android:layout_height="50dp" layout="@layout/laod_animation"
                            tools:ignore="IncludeLayoutParam" />

                        <!-- Episodes Recycler -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/episodes_recycler"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:clipToPadding="false"
                            android:scrollbars="none"
                            android:focusable="false"
                            android:nextFocusUp="@id/TrailerButton"
                            android:nextFocusDown="@id/Cast_widget"
                            android:descendantFocusability="afterDescendants"/>



                    </LinearLayout>

                </LinearLayout>


            </FrameLayout>









            <!-- Cast   -->

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/Cast_widget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:padding="10dp"
                android:paddingHorizontal="32dp"
                android:scrollbars="none"
                android:layout_gravity="center"
                android:orientation="horizontal"
                tools:layout_editor_absoluteY="8dp"
                android:descendantFocusability="afterDescendants"/>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text=" You may also like"
                android:fontFamily="@font/d"
                android:textColor="?attr/AccentColor"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />



                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/Recommendation_widget"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:padding="10dp"
                    android:paddingHorizontal="32dp"
                    android:scrollbars="none"
                    android:orientation="horizontal"
                    tools:layout_editor_absoluteY="8dp"
                    android:descendantFocusability="afterDescendants"/>




        </LinearLayout>
    </ScrollView>

    <include layout="@layout/laod_animation"/>

</androidx.constraintlayout.widget.ConstraintLayout>