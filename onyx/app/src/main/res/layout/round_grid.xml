<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:descendantFocusability="afterDescendants"
    android:orientation="vertical">


        <!-- Profile image container -->
        <androidx.cardview.widget.CardView
            android:id="@+id/CardViewcontiner"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="4dp"
            android:layout_gravity="center_horizontal"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:clickable="true"
            app:cardBackgroundColor="?attr/transparentEffect"
            android:foreground="@drawable/cast_focus"
            app:cardCornerRadius="100dp"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="false">

                <ImageView
                    android:id="@+id/itemImage"
                    android:background="?attr/transparentEffect"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    tools:ignore="ContentDescription" />

        </androidx.cardview.widget.CardView>

        <!-- Name text -->
        <TextView
            android:id="@+id/itemText"
            android:layout_width="90dp"
            android:layout_gravity="center_horizontal"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxLines="1"
            android:paddingHorizontal="3dp"
            android:text="Actor Namddde"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:shadowColor="#000000"
            android:shadowDx="1"
            android:shadowDy="3"
            android:shadowRadius="4"
            android:textSize="12sp"
            android:fontFamily="@font/p"
            tools:ignore="HardcodedText" />


</LinearLayout>