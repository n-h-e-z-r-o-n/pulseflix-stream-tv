<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/sideBar"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layout_marginStart="10dp"
    android:visibility="visible"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent">




        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/navbar_bg"
            android:clickable="true"
            android:contentDescription="Home"
            android:focusable="true"
            android:layout_marginTop="20dp"
            android:nextFocusUp="@id/btnProfile"
            android:nextFocusDown="@id/btnHome"
            android:src="@drawable/ic_search"
            app:tint="@color/nav_icon_color_selector"
            tools:ignore="HardcodedText,TouchTargetSizeCheck"
            android:visibility="gone"/>




            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/navbar_bg"
                android:orientation="vertical"
                android:paddingHorizontal="2dp"
                android:paddingVertical="10dp"
                android:layout_gravity="center_vertical"
                tools:ignore="UselessParent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical" >


                        <ImageButton
                            android:id="@+id/btnHome"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:contentDescription="Home"
                            android:focusable="true"
                            android:nextFocusUp="@id/btnProfile"
                            android:nextFocusDown="@id/btnMvTv"
                            android:src="@drawable/ic_home"
                            app:tint="@color/nav_icon_color_selector"
                            tools:ignore="HardcodedText,TouchTargetSizeCheck" />

                        <TextView
                            android:id="@+id/labelHome"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Home"
                            android:textColor="?attr/FG_color"
                            android:textSize="9sp"
                            android:alpha="0.5"
                            tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
                    </LinearLayout>




                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical" >

                        <ImageButton
                            android:id="@+id/btnMvTv"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:contentDescription="Tv"
                            android:focusable="true"
                            android:nextFocusUp="@id/btnHome"
                            android:nextFocusDown="@id/btnAnime"
                            android:src="@drawable/ic_movie"
                            app:tint="@color/nav_icon_color_selector"
                            tools:ignore="HardcodedText,DuplicateSpeakableTextCheck,TouchTargetSizeCheck" />

                        <TextView
                            android:id="@+id/labelMvTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Shows"
                            android:textColor="?attr/FG_color"
                            android:textSize="9sp"
                            android:alpha="0.5"
                            tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
                    </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="14dp"
                            android:gravity="center_vertical"
                            android:orientation="vertical" >

                            <ImageButton
                                android:id="@+id/btnAnime"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center_horizontal"
                                android:background="@android:color/transparent"
                                android:clickable="true"
                                android:contentDescription="Tv"
                                android:focusable="true"
                                android:nextFocusUp="@id/btnMvTv"
                                android:nextFocusDown="@id/btnFav"
                                android:src="@drawable/ic_anime"
                                app:tint="@color/nav_icon_color_selector"
                                tools:ignore="HardcodedText,TouchTargetSizeCheck" />

                            <TextView
                                android:id="@+id/labelAnime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Anime"
                                android:textColor="?attr/FG_color"
                                android:textSize="9sp"
                                android:alpha="0.5"
                                tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
                        </LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical" >

                        <ImageButton
                            android:id="@+id/btnFav"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center_horizontal"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:focusable="true"
                            android:importantForAccessibility="no"
                            android:nextFocusUp="@id/btnAnime"
                            android:nextFocusDown="@id/btnNotification"
                            android:src="@drawable/ic_fave"
                            app:tint="@color/nav_icon_color_selector"
                            tools:ignore="TouchTargetSizeCheck" />

                        <TextView
                            android:id="@+id/labelFav"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:ellipsize="end"
                            android:fontFamily="@font/b"
                            android:text="Fav"
                            android:textColor="?attr/FG_color"
                            android:textSize="9sp"
                            android:alpha="0.5"
                            tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical" >

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal"
                            >


                            <ImageButton
                                android:id="@+id/btnNotification"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center_horizontal"
                                android:background="@android:color/transparent"
                                android:clickable="true"
                                android:focusable="true"
                                android:importantForAccessibility="no"
                                android:nextFocusUp="@id/btnFav"
                                android:nextFocusDown="@id/btnProfile"
                                android:src="@drawable/ic_notification"
                                app:tint="@color/nav_icon_color_selector"
                                tools:ignore="TouchTargetSizeCheck" />

                            <androidx.cardview.widget.CardView
                                android:id="@+id/notificationBadge"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:layout_gravity="end|top"
                                android:layout_marginTop="12dp"
                                android:layout_marginEnd="6dp"
                                app:cardCornerRadius="5dp"
                                app:cardBackgroundColor="?attr/notBudge"
                                android:visibility="gone"/>
                        </FrameLayout>


                        <TextView
                            android:id="@+id/labelNotification"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="notifs"
                            android:textColor="?attr/FG_color"
                            android:textSize="9sp"
                            android:alpha="0.5"
                            tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
                    </LinearLayout>


            </LinearLayout>





                <androidx.cardview.widget.CardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="bottom|center_horizontal"
                    app:cardBackgroundColor="@android:color/transparent"
                    android:layout_marginBottom="20dp"
                    android:elevation="0dp"
                    app:cardCornerRadius="100dp">

                    <ImageView
                        android:id="@+id/btnProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/nav_icon_color_selector"
                        android:clickable="true"
                        android:focusable="true"
                        android:importantForAccessibility="no"
                        android:nextFocusUp="@id/btnNotification"
                        android:nextFocusDown="@id/btnHome"
                        tools:ignore="TouchTargetSizeCheck,ImageContrastCheck" />

                    <TextView
                        android:id="@+id/labelProfile"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Profile"
                        android:textColor="?attr/FG_color"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:ignore="HardcodedText" />

                </androidx.cardview.widget.CardView>





</FrameLayout>