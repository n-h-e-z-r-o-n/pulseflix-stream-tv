<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/sideBar"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:visibility="visible"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent">


    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        app:cardElevation="5dp"
        app:cardBackgroundColor="?attr/BG_color"
        app:cardCornerRadius="300dp"
        android:layout_margin="10dp"
        android:orientation="vertical"
        tools:ignore="UselessParent">

        <LinearLayout
            android:layout_width="50dp"
            android:layout_height="match_parent"
            android:background="@drawable/navbar_bg"
            android:orientation="vertical"
            android:layout_margin="5dp"
            >


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/sidebarBtnShows"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="Tv"
                    android:focusable="true"
                    android:nextFocusLeft="@id/sidebarBtnShows"
                    android:nextFocusRight="@id/sidebarBtnShows"
                    android:nextFocusUp="@id/sidebarBtnProfile"
                    android:nextFocusDown="@id/sidebarBtnAnime"
                    android:src="@drawable/ic_movie"
                    app:tint="@color/nav_icon_color_selector"
                    tools:ignore="HardcodedText,DuplicateSpeakableTextCheck,TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/sidebarLabelShows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Shows"
                    android:textColor="?attr/FG_color"
                    android:textSize="9sp"
                    tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/sidebarBtnAnime"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:contentDescription="Tv"
                    android:focusable="true"
                    android:nextFocusLeft="@id/sidebarBtnAnime"
                    android:nextFocusRight="@id/sidebarBtnAnime"
                    android:nextFocusUp="@id/sidebarBtnShows"
                    android:nextFocusDown="@id/sidebarBtnProfile"
                    android:src="@drawable/ic_anime"
                    app:tint="@color/nav_icon_color_selector"
                    tools:ignore="HardcodedText,TouchTargetSizeCheck" />

                <TextView
                    android:id="@+id/sidebarLabelAnime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:text="Anime"
                    android:textColor="?attr/FG_color"
                    android:textSize="9sp"
                    tools:ignore="HardcodedText,InefficientWeight,SmallSp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/sidebarBtnProfile"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginBottom="10dp"
                android:layout_gravity="bottom|center_horizontal"
                android:clickable="true"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:foreground="@drawable/cast_focus"
                android:nextFocusLeft="@id/sidebarBtnProfile"
                android:nextFocusRight="@id/sidebarBtnProfile"
                android:nextFocusUp="@id/sidebarBtnAnime"
                android:nextFocusDown="@id/sidebarBtnShows"
                app:cardBackgroundColor="?attr/transparentEffect"
                app:cardCornerRadius="100dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/sidebarBtnProfileImg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/transparentEffect"
                    android:importantForAccessibility="no"
                    tools:ignore="TouchTargetSizeCheck,ImageContrastCheck" />

                <TextView
                    android:id="@+id/sidebarLabelProfile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Profile"
                    android:textColor="?attr/FG_color"
                    android:textSize="14sp"
                    android:visibility="gone"
                    tools:ignore="HardcodedText" />

            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>