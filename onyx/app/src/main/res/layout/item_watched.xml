<!-- res/layout/item_grid.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/grid_item_width"
    android:layout_height="@dimen/grid_item_height"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:id="@+id/rootCard"
    android:orientation="vertical"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="2dp"
    android:layout_margin="3dp"
    card_view:cardBackgroundColor="?attr/BG_color"
    android:foreground="@drawable/card_focus">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="40dp">


        <ImageView
            android:id="@+id/itemImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@raw/test4"
            android:background="@android:color/transparent"
            android:scaleType="fitXY"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="10dp"
            android:layout_gravity="bottom"
            android:background="@drawable/overlay_bottom_gradient"/>


    </FrameLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="4dp"
        android:layout_gravity="bottom">

        <TextView
            android:id="@+id/watchItemTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Redo of Healer"
            android:textColor="?attr/FG_color"
            android:ellipsize="end"
            android:fontFamily="@font/l"
            android:singleLine="true"
            android:textSize="12sp"
            android:alpha="0.7"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/watchItemEpisode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="S1-E1"
                android:textStyle="bold"
                android:fontFamily='serif-monospace'
                android:textColor="?attr/FG_color"
                android:textSize="10sp"
                android:alpha="0.6"
                tools:ignore="HardcodedText" />

            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>


            <TextView
                android:id="@+id/watchItemLastPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:20"
                android:textColor="?attr/AccentColor"
                android:fontFamily="@font/p"
                android:textSize="8sp"
                tools:ignore="HardcodedText,SmallSp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="9sp"
                android:text="/"
                android:alpha="0.6"
                android:textColor="?attr/FG_color"
                tools:ignore="HardcodedText,SmallSp" />

            <TextView
                android:id="@+id/watchItemDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24:47"
                android:alpha="0.6"
                android:textColor="?attr/FG_color"
                android:fontFamily="@font/p"
                android:textSize="8sp"
                tools:ignore="HardcodedText,SmallSp" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/cWatchSeek_bar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="1dp"
            android:layout_marginBottom="4dp"
            android:max="1000"
            android:progress="600"
            android:focusable="false"
            android:clickable="false"
            android:focusableInTouchMode="false"
            android:enabled="false"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:progressTint="?attr/AccentColor"
            android:progressBackgroundTint="?attr/FG_color"
            android:thumbTint="@android:color/transparent" />

    </LinearLayout>


</androidx.cardview.widget.CardView>