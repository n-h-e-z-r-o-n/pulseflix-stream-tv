<!-- res/layout/item_grid.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:focusable="true"
    android:focusableInTouchMode="true"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?attr/BG_color_up"
    android:foreground="@drawable/spotlight_selector"
    android:layout_marginVertical="5dp"
    android:layout_marginEnd="90dp"
    android:layout_marginStart="15dp"
    >



        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintWidth_default="percent"
            app:layout_constraintWidth_percent=".75"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">


                <ImageView
                    android:id="@+id/cardBackdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    tools:ignore="ContentDescription" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:visibility="gone"
                    android:background="@drawable/overlay_bottom_gradient"
                    android:orientation="horizontal"
                    android:layout_gravity="bottom" />

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/overlay_left_gradient_light"
                    android:orientation="horizontal"
                    android:layout_gravity="start" />

        </FrameLayout>



        <LinearLayout
            android:layout_width="500dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom"
            android:layout_margin="15dp">

            <TextView
                android:id="@+id/cardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:ellipsize="end"
                android:maxLines="3"
                android:singleLine="false"
                android:text="Sakamoto Days Part 2"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/p"
                android:shadowColor="#80000000"
                android:shadowDx="5"
                android:shadowDy="6"
                android:shadowRadius="4"
                tools:ignore="HardcodedText,Suspicious0dp"/>

                <TextView
                    android:id="@+id/cardGenre"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="Action"
                    android:singleLine="false"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="13sp"
                    tools:ignore="HardcodedText,Suspicious0dp"
                    android:textStyle="bold"
                    android:layout_marginBottom="9dp"
                    android:fontFamily="sans-serif"
                    android:alpha="0.8"
                    />

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"

                    android:gravity="center">


                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        app:cardCornerRadius="4dp"
                        android:layout_gravity="center_horizontal"
                        app:cardBackgroundColor="?attr/AccentColor"
                        android:elevation="0dp"
                        >

                        <TextView
                            android:id="@+id/cardQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="HD"
                            android:layout_marginHorizontal="3dp"
                            android:singleLine="true"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            tools:ignore="HardcodedText,Suspicious0dp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:textStyle="bold"
                            />

                    </androidx.cardview.widget.CardView>





                        <TextView
                            android:id="@+id/cardPg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="PG-13"
                            android:singleLine="true"
                            android:textColor="#FFFFFF"
                            android:shadowColor="#80000000"
                            android:shadowDx="5"
                            android:shadowDy="6"
                            android:shadowRadius="4"
                            android:textSize="10sp"
                            tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:textStyle="bold"
                            android:layout_marginStart="9dp"


                            />




                    <TextView
                        android:id="@+id/cardType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Mv"
                        android:fontFamily="@font/a"
                        android:singleLine="true"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText,Suspicious0dp"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:layout_marginStart="9dp"
                        />


                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="bottom"
                            android:src="@drawable/ic_stars"
                            app:tint="?attr/AccentColor"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:id="@+id/cardRating"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="bottom"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="9.7"
                            android:singleLine="false"
                            android:textColor="#FFFFFF"
                            android:shadowColor="#80000000"
                            android:shadowDx="5"
                            android:shadowDy="6"
                            android:shadowRadius="4"
                            android:textSize="13sp"
                            tools:ignore="HardcodedText,Suspicious0dp"
                            android:gravity="center"/>

                    </LinearLayout>


                    <TextView
                        android:id="@+id/cardYear"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="bottom"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="2025"
                        android:singleLine="false"
                        android:textColor="#FFFFFF"
                        android:shadowColor="#80000000"
                        android:shadowDx="5"
                        android:shadowDy="6"
                        android:shadowRadius="4"
                        android:textSize="13sp"
                        tools:ignore="HardcodedText,Suspicious0dp"
                        android:gravity="center"
                        android:layout_marginStart="9dp"/>


                </LinearLayout>




                <TextView
                    android:id="@+id/cardOverview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:ellipsize="end"
                    android:maxLines="10"
                    android:singleLine="false"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="13sp"
                    android:layout_marginBottom="20dp"
                    tools:ignore="Suspicious0dp"
                   />


        </LinearLayout>



</androidx.cardview.widget.CardView>