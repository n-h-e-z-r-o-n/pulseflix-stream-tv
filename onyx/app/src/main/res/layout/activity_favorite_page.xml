<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/BG_color">



    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@raw/test2"
        tools:ignore="ContentDescription" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/mainBox"
        android:layout_margin="60dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        android:layout_gravity="center"
        app:cardBackgroundColor="?attr/transparentEffect"
        app:cardCornerRadius="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            tools:ignore="RtlSymmetry"
            android:background="?attr/transparentEffect"
            android:nextFocusLeft="@id/btnFav">

            <androidx.cardview.widget.CardView
                android:layout_width="140dp"
                android:layout_height="match_parent"
                app:cardCornerRadius="10dp"
                android:layout_margin="10dp">

                    <LinearLayout
                        android:layout_width="140dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="10dp"
                        android:background="?attr/BG_color_up" >





                        <LinearLayout
                            android:id="@+id/FavBtn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="15dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:gravity="center_vertical"
                            android:nextFocusLeft="@+id/FavBtn"
                            android:nextFocusUp="@+id/cWatchBtn"
                            android:nextFocusDown="@+id/cWatchBtn"
                            android:background="@drawable/background_hovor"
                            android:padding="5dp"
                            tools:ignore="UseCompoundDrawables,UselessParent">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/heart1"
                                app:tint="?attr/FG_color"
                                tools:ignore="ContentDescription" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_marginStart="9dp"
                                android:fontFamily="@font/o"
                                android:text="Favourites All"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                tools:ignore="HardcodedText,SmallSp" />

                        </LinearLayout>


                        <LinearLayout
                            android:id="@+id/cWatchBtn"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="15dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:gravity="center_vertical"
                            android:nextFocusLeft="@+id/cWatchBtn"
                            android:nextFocusUp="@+id/FavBtn"
                            android:nextFocusDown="@+id/FavBtn"
                            android:padding="5dp"
                            android:background="@drawable/background_hovor"
                            tools:ignore="UselessParent">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:src="@drawable/clock"
                                app:tint="?attr/FG_color"
                                tools:ignore="ContentDescription" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="9dp"
                                android:text="Watching All"
                                android:fontFamily="@font/o"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                tools:ignore="HardcodedText,SmallSp" />

                        </LinearLayout>

                    </LinearLayout>

            </androidx.cardview.widget.CardView>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:id="@+id/FavBox"
                tools:ignore="RtlSymmetry"
                android:visibility="gone"
                >


                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="40dp"
                    android:layout_marginVertical="10dp"
                    app:cardBackgroundColor="?attr/BG_color"
                    app:cardCornerRadius="20dp"
                    android:orientation="horizontal">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_gravity="end">

                        <ImageView
                            android:id="@+id/FavBackdrop"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="fitCenter"
                            android:src="@raw/test4"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent" />

                        <!-- Bottom Gradient Overlay: covers 30% of height -->
                        <View
                            android:id="@+id/BottomOverlay"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:background="@drawable/overlay_bottom_gradient"

                            app:layout_constraintBottom_toBottomOf="@id/FavBackdrop"
                            app:layout_constraintStart_toStartOf="@id/FavBackdrop"
                            app:layout_constraintEnd_toEndOf="@id/FavBackdrop"
                            app:layout_constraintHeight_percent="0.35" />

                        <!-- Left Gradient Overlay: covers 25% of width -->
                        <View
                            android:id="@+id/LeftOverlay"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:background="@drawable/overlay_left_gradient"
                            app:layout_constraintStart_toStartOf="@id/FavBackdrop"
                            app:layout_constraintTop_toTopOf="@id/FavBackdrop"
                            app:layout_constraintBottom_toBottomOf="@id/FavBackdrop"
                            app:layout_constraintWidth_percent="0.40" />

                    </androidx.constraintlayout.widget.ConstraintLayout>


                    <LinearLayout
                        android:id="@+id/FaveData"
                        android:layout_width="450dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="bottom"
                        android:gravity="bottom"
                        android:layout_marginStart="10dp"
                        android:layout_marginBottom="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/FavTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:ellipsize="end"
                            android:maxLines="3"
                            android:text="Sakamoto Days Part 2"
                            android:singleLine="false"
                            android:textColor="?attr/FG_color"
                            android:textSize="40sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="5dp"
                            android:fontFamily="@font/l"
                            tools:ignore="HardcodedText" />
                        <TextView
                            android:id="@+id/FavGenre"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Action"
                            android:singleLine="false"
                            android:textColor="?attr/FG_color"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp"
                            android:fontFamily="@font/q"
                            tools:ignore="HardcodedText" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="20dp"
                            android:orientation="horizontal"
                            android:layout_marginBottom="10dp"
                            android:alpha="0.5">

                            <TextView
                                android:id="@+id/FavType"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="bottom"
                                android:ellipsize="end"
                                android:maxLines="7"
                                android:text=""
                                android:singleLine="false"
                                android:textColor="?attr/AccentColor"
                                android:textSize="15sp"
                                android:fontFamily="@font/a"
                                android:gravity="center"
                                android:textStyle="bold"
                                android:layout_marginEnd="15dp"
                                />

                            <androidx.cardview.widget.CardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="3dp"
                                android:text="IMDB"

                                android:textSize="11sp"
                                app:cardBackgroundColor="#DAA520"
                                tools:ignore="HardcodedText"
                                android:textStyle="bold">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="IMDb"
                                    android:paddingVertical="2dp"
                                    android:paddingHorizontal="5dp"
                                    android:textColor="#000000"
                                    android:textStyle="bold"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/p"
                                    tools:ignore="HardcodedText" />

                            </androidx.cardview.widget.CardView>

                            <TextView
                                android:id="@+id/FavRating"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="bottom"
                                android:ellipsize="end"
                                android:maxLines="7"
                                android:text=""
                                android:singleLine="false"
                                android:textColor="?attr/FG_color"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="italic|bold"
                                android:layout_marginEnd="15dp"
                                android:layout_marginStart="2dp"
                                />
                            <TextView
                                android:id="@+id/FavYear"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:layout_gravity="bottom"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text=""
                                android:singleLine="false"
                                android:textColor="?attr/FG_color"
                                android:textSize="13sp"
                                android:gravity="center"
                                android:textStyle="italic|bold"
                                android:layout_marginEnd="15dp"
                                />





                        </LinearLayout>

                        <TextView
                            android:id="@+id/FavOverview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:ellipsize="end"
                            android:maxLines="5"
                            android:singleLine="false"
                            android:text="                                                                                                    	at com.android.server.wm.WindowOrganizerController.onTransact(WindowOrganizerController.java:223)"
                            android:textColor="?attr/FG_color"
                            android:fontFamily="@font/p"
                            android:textSize="12sp"
                            android:layout_marginBottom="20dp"
                            />

                        <LinearLayout
                            android:id="@+id/RemoveFaveItem"
                            android:layout_width="wrap_content"
                            android:layout_height="30dp"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:clickable="true"
                            android:background="@drawable/watch_button"
                            android:nextFocusLeft="@+id/sideBar"
                            android:paddingStart="9dp"
                            android:paddingEnd="9dp"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="TODO"
                                android:src="@drawable/remove_fave"
                                app:tint="?attr/AccentColor"
                                tools:ignore="ContentDescription" />



                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Remove From Favorites"
                                android:textColor="@android:color/white"
                                android:fontFamily="@font/q"
                                android:textSize="8sp"
                                android:layout_marginStart="2dp"
                                tools:ignore="HardcodedText,SmallSp"

                                />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/favoritesRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:layout_gravity="bottom"
                    android:scrollbars="none"
                    android:layout_marginBottom="5dp"/>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:id="@+id/watchingBox"
                android:orientation="vertical">


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/watchingRecycler"
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:clipToPadding="false"
                    android:scrollbars="none"
                    tools:ignore="RtlSymmetry"/>

            </LinearLayout>

        </LinearLayout>





        <TextView
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="150dp"
            android:textSize="35sp"
            android:text="Your favorites list is feeling a little lonely. Discover shows and add them to your favorites!"
            android:gravity="center"
            android:fontFamily="@font/i"
            android:textColor="?attr/AccentColor"
            android:visibility="gone"
            android:background="?attr/BG_color"
            android:shadowColor="?attr/FG_color"
            android:shadowDx="2"
            android:shadowDy="3"
            android:shadowRadius="4"
            tools:ignore="HardcodedText" />

    </androidx.cardview.widget.CardView>


    <include layout="@layout/side_bar"/>

</androidx.constraintlayout.widget.ConstraintLayout>




