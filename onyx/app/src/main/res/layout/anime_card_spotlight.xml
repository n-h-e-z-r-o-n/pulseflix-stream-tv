<!-- res/layout/item_grid.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/spotlightAnimesCard"
    android:layout_width="750dp"
    android:layout_height="match_parent"
    android:nextFocusDown="@id/cardButton"
    android:nextFocusUp="@+id/searchBarAnime"
    android:focusable="true"
    android:layout_marginStart="50dp"
    android:layout_marginBottom="10dp"

    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="?attr/BG_color_up"
    android:foreground="@drawable/spotlight_selector"
    android:descendantFocusability="beforeDescendants">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        >

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end">



        <ImageView
            android:id="@+id/SliderBackdrop"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@raw/test3"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:visibility="gone"
            android:background="@drawable/overlay_bottom_gradient"
            android:orientation="horizontal"
            android:layout_gravity="bottom" />

        <LinearLayout
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:background="@drawable/overlay_left_gradient_light"
            android:orientation="horizontal"
            android:layout_gravity="start" />
        </FrameLayout>


        <LinearLayout
            android:layout_width="399dp"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="10dp"
            android:paddingBottom="10dp"
            android:gravity="bottom"
            tools:ignore="RtlSymmetry">

            <TextView
                android:id="@+id/cardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginBottom="5dp"
                android:ellipsize="end"
                android:fontFamily="@font/p"
                android:maxLines="3"
                android:shadowColor="#80000000"
                android:shadowDx="5"
                android:shadowDy="6"
                android:shadowRadius="4"
                android:singleLine="false"
                android:text="Sakamoto Days Part 2"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText,Suspicious0dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/cardPg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="PG-13"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText,SmallSp,Suspicious0dp"


                    />


                <TextView
                    android:id="@+id/cardType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:text="Mv"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="13sp"
                    tools:ignore="HardcodedText,Suspicious0dp" />


                <TextView
                    android:id="@+id/cardRuntime"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="false"
                    android:text="9.7"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="13sp"
                    tools:ignore="HardcodedText,Suspicious0dp" />


                <TextView
                    android:id="@+id/cardYear"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="9dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:singleLine="false"
                    android:text="2025"
                    android:textColor="#FFFFFF"
                    android:shadowColor="#80000000"
                    android:shadowDx="5"
                    android:shadowDy="6"
                    android:shadowRadius="4"
                    android:textSize="13sp"
                    tools:ignore="HardcodedText,Suspicious0dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="30dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="10dp"
                    android:elevation="0dp"
                    app:cardBackgroundColor="#80DAA520"
                    app:cardCornerRadius="5dp">

                    <TextView
                        android:id="@+id/cardQuality"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:text="HD"
                        android:textColor="?attr/BG_color"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:ignore="HardcodedText,Suspicious0dp" />

                </androidx.cardview.widget.CardView>


                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="5dp"
                    android:elevation="0dp"
                    app:cardBackgroundColor="#800F52BA"
                    app:cardCornerRadius="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="5dp"
                        tools:ignore="UseCompoundDrawables">


                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_sub"
                            app:tint="#FFFFFF"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:id="@+id/cardSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="2"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText,Suspicious0dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="5dp"
                    android:elevation="0dp"
                    app:cardBackgroundColor="#8073C2FB"
                    app:cardCornerRadius="5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="5dp">


                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:src="@drawable/ic_dub"
                            app:tint="#FFFFFF"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:id="@+id/cardDub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:singleLine="true"
                            android:text="2"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText,Suspicious0dp" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>


            </LinearLayout>


            <TextView
                android:id="@+id/cardOverview"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_gravity="bottom"
                android:layout_marginBottom="20dp"
                android:ellipsize="end"
                android:maxLines="5"
                android:singleLine="false"
                android:textColor="#FFFFFF"
                android:shadowColor="#80000000"
                android:shadowDx="4"
                android:shadowDy="5"
                android:shadowRadius="3"
                android:textSize="14sp"
                tools:ignore="Suspicious0dp" />

        </LinearLayout>


    </FrameLayout>



</androidx.cardview.widget.CardView>
