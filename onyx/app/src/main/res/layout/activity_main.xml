<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_background"
    tools:context=".MainActivity">



        <!-- Logo -->
        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="24dp"
            android:contentDescription="@string/app_name"
            android:src="@raw/logo"
            android:visibility="gone"
            app:layout_constraintDimensionRatio="1.5"
            tools:ignore="ContentDescription"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            />

        <!-- ONYX Title -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            app:cardBackgroundColor="?attr/transparentEffect"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="100dp"
            >
            <TextView
                android:id="@+id/onyxTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:text="ONYX"
                android:gravity="center"
                android:layout_gravity="center"
                android:textSize="150sp"
                android:textColor="?attr/FG_color"
                android:shadowColor="?attr/AccentColor"
                android:maxLines="1"
                android:shadowDx="5"
                android:shadowDy="6"
                android:shadowRadius="4"
                android:fontFamily="@font/j"
                tools:ignore="HardcodedText" />

        </androidx.cardview.widget.CardView>




        <!-- Loading Animation -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:orientation="vertical"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            tools:ignore="UseCompoundDrawables">

            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="3dp"
                android:background="@drawable/loading_track"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="20dp"
                android:clipChildren="true"
                android:clipToPadding="true">

                <View
                    android:id="@+id/loading_bar"
                    android:layout_width="60dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/loading_bar"/>
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="©2026 ONYX MEDIA GROUP"
                android:textColor="?attr/FG_color"
                android:textSize="12sp"
                android:alpha="0.3"
                android:fontFamily="@font/p"
                tools:ignore="HardcodedText"
                android:layout_marginBottom="20dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_movie"
                    tools:ignore="ContentDescription"
                    app:tint="?attr/FG_color"
                    android:alpha="0.3"
                    android:layout_marginHorizontal="5dp"/>
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_laptop"
                    tools:ignore="ContentDescription"
                    app:tint="?attr/FG_color"
                    android:alpha="0.3"
                    android:layout_marginHorizontal="5dp"/>
                <ImageView
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:src="@drawable/ic_tv"
                    tools:ignore="ContentDescription"
                    app:tint="?attr/FG_color"
                    android:alpha="0.3"
                    android:layout_marginHorizontal="5dp"/>
            </LinearLayout>
        </LinearLayout>




</FrameLayout>
