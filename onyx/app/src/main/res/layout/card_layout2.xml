<!-- res/layout/item_grid.xml -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="600dp"
    android:layout_height="300dp"
    android:focusable="true"
    android:id="@+id/spotlightMovie"
    app:cardCornerRadius="20dp"
    android:focusableInTouchMode="true"
    android:nextFocusDown="@id/SliderButton"
    android:background="@drawable/season_selector"
    android:foreground="@drawable/season_selector"
    android:elevation="2dp"
    android:layout_margin="20dp"
    android:nextFocusUp="@id/HomeSearchInput">



    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/BG_color">


        <ImageView
            android:id="@+id/SliderBackdrop"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:adjustViewBounds="true"
            android:scaleType="centerCrop"
            android:src="@raw/test2"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/overlay_bottom_gradient"
            android:orientation="horizontal"
            android:layout_gravity="bottom" />

        <LinearLayout
            android:layout_width="450dp"
            android:layout_height="match_parent"
            android:background="@drawable/overlay_left_gradient"
            android:orientation="horizontal"
            android:layout_gravity="start" />

        <TextView
            android:id="@+id/tetle"
            android:textSize="40sp"
            android:text="34"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </FrameLayout>


</androidx.cardview.widget.CardView>