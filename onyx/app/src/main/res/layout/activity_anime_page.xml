<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Anime_Page"
    android:background="@android:color/transparent">



    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@raw/background_2"
        tools:ignore="ContentDescription" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/mainBox"
        android:layout_margin="0dp"
        app:cardElevation="0dp"
        app:cardUseCompatPadding="false"
        android:layout_gravity="center"
        app:cardBackgroundColor="?attr/transparentEffect"
        app:cardCornerRadius="0dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/transparentEffect"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="?attr/transparentEffect"/>



        <LinearLayout
            android:id="@+id/animeNavBar"
            android:layout_width="70dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_vertical"
            android:layout_marginVertical="5dp"
            android:orientation="vertical"
            android:gravity="center"
            android:elevation="15dp"
            >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_gravity="center_vertical"
            app:cardCornerRadius="20dp"
            android:elevation="15dp"
            app:cardBackgroundColor="?attr/BG_color_up">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="5dp"
                android:background="@android:color/transparent" >

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:alpha="0.6"
                    tools:ignore="UseCompoundDrawables">


                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_anime_logo"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="match_parent"
                        android:gravity="center"
                        android:layout_gravity="center_vertical"
                        android:layout_height="wrap_content"
                        android:text="Anime"
                        android:fontFamily="@font/n"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:textColor="?attr/FG_color"
                        tools:ignore="HardcodedText"
                        android:shadowColor="?attr/AccentColor"
                        android:shadowDx="2"
                        android:shadowDy="2"
                        android:shadowRadius="4"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/HomeAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusLeft="@+id/HomeAnimeBtn"
                    android:nextFocusUp="@+id/cNotificationAnimeBtn"
                    android:nextFocusDown="@+id/DubbedAnimeBtn"
                    android:background="@drawable/background_hovor"
                    android:padding="5dp"
                    tools:ignore="UseCompoundDrawables,UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_anime_home"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:fontFamily="@font/n"
                        android:text="Home"
                        android:singleLine="true"
                        android:textColor="?attr/FG_color"
                        android:textSize="18sp"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/DubbedAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="15dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusLeft="@+id/DubbedAnimeBtn"
                    android:nextFocusUp="@+id/HomeAnimeBtn"
                    android:nextFocusDown="@+id/PopularAnimeBtn"
                    android:background="@drawable/background_hovor"
                    android:padding="5dp"
                    tools:ignore="UseCompoundDrawables,UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_anime_dubbed"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:fontFamily="@font/n"
                        android:singleLine="true"
                        android:text="Dubbed"
                        android:textColor="?attr/FG_color"
                        android:textSize="18sp"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/PopularAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusLeft="@+id/PopularAnimeBtn"
                    android:nextFocusUp="@+id/DubbedAnimeBtn"
                    android:nextFocusDown="@+id/SearchAnimeBtn"
                    android:background="@drawable/background_hovor"
                    android:padding="5dp"
                    tools:ignore="UseCompoundDrawables,UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_anime_popular"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:fontFamily="@font/n"
                        android:text="Popular"
                        android:textColor="?attr/FG_color"
                        android:textSize="17sp"
                        android:singleLine="true"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/SearchAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusLeft="@+id/SearchAnimeBtn"
                    android:nextFocusUp="@+id/PopularAnimeBtn"
                    android:nextFocusDown="@+id/FavAnimeBtn"
                    android:background="@drawable/background_hovor"
                    android:padding="5dp"
                    tools:ignore="UseCompoundDrawables,UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/ic_anime_search"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:fontFamily="@font/n"
                        android:text="Search"
                        android:singleLine="true"
                        android:textColor="?attr/FG_color"
                        android:textSize="18sp"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/FavAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusLeft="@+id/FavAnimeBtn"
                    android:nextFocusUp="@+id/SearchAnimeBtn"
                    android:nextFocusDown="@+id/cWatchAnimeBtn"
                    android:background="@drawable/background_hovor"
                    android:padding="5dp"
                    tools:ignore="UseCompoundDrawables,UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/heart1"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:fontFamily="@font/n"
                        android:text="Favorites"
                        android:textColor="?attr/FG_color"
                        android:textSize="18sp"
                        android:singleLine="true"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>


                <LinearLayout
                    android:id="@+id/cWatchAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusUp="@+id/FavAnimeBtn"
                    android:nextFocusDown="@+id/cNotificationAnimeBtn"
                    android:nextFocusLeft="@+id/cWatchAnimeBtn"
                    android:padding="5dp"
                    android:background="@drawable/background_hovor"
                    tools:ignore="UselessParent">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:src="@drawable/clock"
                        app:tint="?attr/FG_color"
                        tools:ignore="ContentDescription" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="9dp"
                        android:text="Watching"
                        android:fontFamily="@font/n"
                        android:textColor="?attr/FG_color"
                        android:textSize="17sp"
                        android:singleLine="true"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cNotificationAnimeBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="9dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:gravity="center_vertical"
                    android:nextFocusUp="@+id/cWatchAnimeBtn"
                    android:nextFocusDown="@+id/HomeAnimeBtn"
                    android:nextFocusLeft="@+id/cNotificationAnimeBtn"
                    android:padding="5dp"
                    android:background="@drawable/background_hovor"
                    tools:ignore="UselessParent">

                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <androidx.cardview.widget.CardView
                            android:id="@+id/cNotificationAnimeIcon"
                            android:layout_width="9dp"
                            android:layout_height="9dp"
                            app:cardCornerRadius="50dp"
                            android:layout_gravity="right"
                            android:visibility="gone"
                            app:cardBackgroundColor="@android:color/holo_red_light"
                            tools:ignore="RtlHardcoded" />

                        <ImageView
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:src="@drawable/ic_notification"
                            app:tint="?attr/FG_color"
                            android:layout_marginRight="5dp"
                            tools:ignore="ContentDescription" />
                    </FrameLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Notification"
                        android:fontFamily="@font/n"
                        android:singleLine="true"
                        android:textColor="?attr/FG_color"
                        android:textSize="18sp"
                        tools:ignore="HardcodedText,SmallSp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        </LinearLayout>



    <LinearLayout
        android:id="@+id/AnimeHomeContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:overScrollMode="never"
        android:layout_marginVertical="10dp"
        android:layout_marginStart="70dp"
        tools:ignore="RtlSymmetry">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:overScrollMode="never"
            tools:ignore="UselessParent">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">



                <!-- //////////////////////// HOME PAGE ///////////////////////////////////////////// -->

                <LinearLayout
                    android:id="@+id/HomePageAnime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    tools:ignore="UselessParent"
                    android:visibility="gone">


                    <FrameLayout
                        android:id="@+id/spotlightAnimes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:descendantFocusability="afterDescendants"
                        android:clipChildren="false"
                        android:clipToPadding="false"/>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="vertical"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=" Trending Anime"
                            android:textStyle="bold"
                            android:fontFamily="@font/p"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="3"
                            tools:ignore="HardcodedText" />


                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/Anime_Trending_widget"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clipToPadding="false"
                            android:nextFocusUp="@+id/spotlightAnimes"
                            android:nextFocusDown="@+id/Anime_Airing_widget"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            tools:ignore="NestedWeights" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=" Top Airing Anime"
                            android:textStyle="bold"
                            android:fontFamily="@font/p"
                            android:textSize="18sp"
                            android:textColor="#FFFFFF"
                            android:shadowColor="#000000"
                            android:shadowDx="2"
                            android:shadowDy="2"
                            android:shadowRadius="3"
                            tools:ignore="HardcodedText"
                            android:layout_marginTop="10dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/Anime_Airing_widget"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clipToPadding="false"
                            android:overScrollMode="never"
                            android:scrollbars="none"
                            tools:ignore="NestedWeights"
                            android:nextFocusUp="@+id/Anime_Trending_widget"
                            android:nextFocusDown="@+id/Anime_Airing_widget"/>


                    </LinearLayout>

                </LinearLayout>

                <!-- //////////////////////// DUBBED PAGE ////////////////////////////////////// -->
                <LinearLayout
                    android:id="@+id/DubbedPageAnime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dubbed Page Anime"
                        android:textStyle="bold"
                        android:fontFamily="@font/p"
                        android:textSize="13sp"
                        android:textColor="?attr/FG_color"
                        android:alpha="0.4"
                        android:layout_marginTop="10dp"
                        tools:ignore="HardcodedText"/>


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/dubbedRecycler"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:clipToPadding="false"
                        android:scrollbars="none"
                        tools:ignore="RtlSymmetry"/>

                </LinearLayout>



                <!-- //////////////////////// POPULAR PAGE ////////////////////////////////////// -->
                <LinearLayout
                    android:id="@+id/PopularPageAnime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Most Popular Animes"
                        android:textStyle="bold"
                        android:fontFamily="@font/p"
                        android:textSize="13sp"
                        android:alpha="0.4"
                        android:layout_marginTop="10dp"
                        android:textColor="?attr/FG_color"
                        tools:ignore="HardcodedText"/>


                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/popularRecycler"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:layout_gravity=""
                        android:clipToPadding="false"
                        android:scrollbars="none"
                        tools:ignore="RtlSymmetry"/>

                </LinearLayout>

                <!-- //////////////////////// SEARCH PAGE ////////////////////////////////////// -->



                <LinearLayout
                    android:id="@+id/SearchPageAnime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="280dp"
                        android:layout_height="match_parent"
                        android:orientation="vertical">




                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="35dp"
                                android:layout_marginTop="5dp"
                                android:layout_marginBottom="30dp"
                                android:background="?attr/transparentEffect"
                                android:orientation="horizontal"
                                android:focusableInTouchMode="true">



                                <!-- Search Icon -->
                                <ImageView
                                    android:layout_width="25dp"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_anime_filter"
                                    app:tint="?attr/AccentColor"
                                    android:padding="2dp"
                                    android:background="?attr/transparentEffect"
                                    android:layout_gravity="center_vertical"
                                    tools:ignore="ContentDescription" />


                                <!-- Search Text Input -->



                                <EditText
                                    android:id="@+id/AnimeSearchInput"
                                    android:layout_width="250dp"
                                    android:layout_height="match_parent"
                                    android:hint="Search for anime..."
                                    android:textColor="?attr/FG_color"
                                    android:textColorHint="?attr/FG_color"
                                    android:padding = "3dp"
                                    android:inputType="text"
                                    android:textSize="15sp"
                                    android:singleLine="true"
                                    android:clickable="false"
                                    android:focusable="false"
                                    android:fontFamily="@font/p"
                                    android:focusableInTouchMode="true"
                                    android:background="?attr/transparentEffect"
                                    android:imeOptions="actionSearch"
                                    tools:ignore="Autofill,HardcodedText" />

                            </LinearLayout>

                        <include layout="@layout/keyboard_layout"/>

                    </LinearLayout>







                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="match_parent"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/searchTextDisplay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Anime Search Results"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-smallcaps"
                            android:textSize="20sp"
                            android:paddingStart="10dp"
                            android:textColor="?attr/FG_color"
                            tools:ignore="HardcodedText,RtlSymmetry"
                            android:layout_marginTop="7dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="490dp"
                            android:descendantFocusability="afterDescendants"
                            >

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/SearchRecycler"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:clipToPadding="false"
                                android:overScrollMode="never"
                                android:focusable="false"
                                android:focusableInTouchMode="false"
                                android:scrollbars="none"
                                android:layout_margin="4dp"
                                tools:ignore="NestedWeights"

                                />
                        </LinearLayout>
                    </LinearLayout>



                </LinearLayout>

                <!-- //////////////////////// ANIME FAVORITE PAGE ////////////////////////////////////// -->
                <LinearLayout
                    android:id="@+id/FavPageAnime"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone">



                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Favorite List"
                        android:textStyle="bold"
                        android:fontFamily="@font/p"
                        android:textSize="13sp"
                        android:textColor="?attr/FG_color"
                        tools:ignore="HardcodedText"
                        android:alpha="0.5"
                        android:layout_marginTop="10dp"/>


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginVertical="10dp"
                        app:cardBackgroundColor="?attr/BG_color"
                        app:cardCornerRadius="20dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="end">

                            <ImageView
                                android:id="@+id/FavBackdrop"
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:adjustViewBounds="true"
                                android:scaleType="fitCenter"
                                android:src="@raw/test4"
                                app:layout_constraintTop_toTopOf="parent"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />

                            <!-- Bottom Gradient Overlay: covers 30% of height -->
                            <View
                                android:id="@+id/BottomOverlay"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:background="@drawable/overlay_bottom_gradient"

                                app:layout_constraintBottom_toBottomOf="@id/FavBackdrop"
                                app:layout_constraintStart_toStartOf="@id/FavBackdrop"
                                app:layout_constraintEnd_toEndOf="@id/FavBackdrop"
                                app:layout_constraintHeight_percent="0.35" />

                            <!-- Left Gradient Overlay: covers 25% of width -->
                            <View
                                android:id="@+id/LeftOverlay"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:background="@drawable/overlay_left_gradient"
                                app:layout_constraintStart_toStartOf="@id/FavBackdrop"
                                app:layout_constraintTop_toTopOf="@id/FavBackdrop"
                                app:layout_constraintBottom_toBottomOf="@id/FavBackdrop"
                                app:layout_constraintWidth_percent="0.40" />

                        </androidx.constraintlayout.widget.ConstraintLayout>


                        <LinearLayout
                            android:id="@+id/FaveData"
                            android:layout_width="450dp"
                            android:layout_height="match_parent"
                            android:layout_gravity="bottom"
                            android:gravity="bottom"
                            android:layout_marginStart="10dp"
                            android:layout_marginBottom="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/FavTitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:ellipsize="end"
                                android:maxLines="3"
                                android:text="Sakamoto Days Part 2"
                                android:singleLine="false"
                                android:textColor="?attr/FG_color"
                                android:textSize="40sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp"
                                android:fontFamily="@font/l"
                                tools:ignore="HardcodedText" />
                            <TextView
                                android:id="@+id/FavGenre"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Action"
                                android:singleLine="false"
                                android:textColor="?attr/FG_color"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="10dp"
                                android:fontFamily="@font/q"
                                tools:ignore="HardcodedText" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:orientation="horizontal"
                                android:layout_marginBottom="10dp"
                                android:alpha="0.5">

                                <TextView
                                    android:id="@+id/FavType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="bottom"
