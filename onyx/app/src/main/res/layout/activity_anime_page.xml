                                android:textColor="?attr/FG_color"
                                android:fontFamily="@font/p"
                                android:textSize="12sp"
                                android:layout_marginBottom="20dp"
                                />

                            <LinearLayout
                                android:id="@+id/RemoveFaveItem"
