                                    android:text=""
                                    android:singleLine="false"
                                    android:textColor="?attr/FG_color"
                                    android:textSize="13sp"
                                    android:gravity="center"
                                    android:textStyle="italic|bold"
                                    android:layout_marginEnd="15dp"
                                    />





                            </LinearLayout>

                            <TextView
                                android:id="@+id/FavOverview"
