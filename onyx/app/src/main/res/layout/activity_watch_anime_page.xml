<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/BG_color"
    tools:context=".Watch_Anime_Page">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:background="?attr/BG_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/transparentEffect"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:background="?attr/transparentEffect"
            android:layout_height="400dp">


            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/backdrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@raw/test2"
                    tools:ignore="ContentDescription,ImageContrastCheck" />

                <LinearLayout
                    android:id="@+id/blurContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="#97000000"
                    android:orientation="vertical"
                    android:gravity="center"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/overlay_bottom_gradient"
                    android:layout_gravity="bottom"/>

            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                >

                <androidx.cardview.widget.CardView
                    android:layout_width="210dp"
                    android:layout_height="315dp"
                    android:layout_margin="15dp"
                    android:layout_gravity="center_vertical"
                    app:cardBackgroundColor="?attr/transparentEffect"
                    app:cardCornerRadius="15dp">
                        <ImageView
                            android:id="@+id/WatchImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitXY"
                            android:src="@raw/test4"
                            tools:ignore="ContentDescription,ImageContrastCheck" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingTop="20dp">

                    <TextView
                        android:id="@+id/watchTitle" android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="34sp"
                        android:fontFamily="@font/p"
                        android:text="Campfire Cooking in Another World with My Absurd Skill Season 2"
                        android:textColor="?attr/FG_color"
                        tools:ignore="HardcodedText"
                        android:shadowColor="#000000"
                        android:shadowDx="5"
                        android:shadowDy="6"
                        android:shadowRadius="4"/>


                    <TextView
                        android:id="@+id/watchGenres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:fontFamily="@font/l"
                        android:text=""
                        android:textColor="?attr/FG_color"
                        tools:ignore="HardcodedText,SmallSp" />





                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="5dp"
                            android:layout_gravity="center_horizontal"
                            app:cardBackgroundColor="@android:color/darker_gray"
                            android:elevation="0dp">
                              <TextView
                                    android:id="@+id/watchRating"
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:layout_gravity="center"
                                    android:ellipsize="end"
                                    android:gravity="center"
                                    android:maxLines="1"
                                    android:singleLine="true"
                                    android:text="PG-13"
                                    android:fontFamily="@font/p"
                                    android:layout_marginHorizontal="4dp"
                                    android:textColor="@android:color/black"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    tools:ignore="HardcodedText,SmallSp,Suspicious0dp"  />

                        </androidx.cardview.widget.CardView>


                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="5dp"
                            android:layout_gravity="center_horizontal"
                            app:cardBackgroundColor="?attr/AccentColor"
                            android:elevation="0dp"
                            android:layout_marginStart="10dp"
                            >

                            <TextView
                                android:id="@+id/watchQuality"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:ellipsize="end"
                                android:gravity="center"
                                android:maxLines="1"
                                android:singleLine="true"
                                android:text="HD"
                                android:fontFamily="@font/p"
                                android:textColor="?attr/FG_color"
                                android:textSize="18sp"
                                android:layout_marginHorizontal="4dp"
                                tools:ignore="HardcodedText,Suspicious0dp" />

                        </androidx.cardview.widget.CardView>



                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="5dp"
                            android:layout_gravity="center_horizontal"
                            app:cardBackgroundColor="?attr/BG_color_up"
                            android:elevation="0dp"
                            android:layout_marginStart="5dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="5dp"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:orientation="horizontal"
                                tools:ignore="UseCompoundDrawables">


                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_sub"
                                    android:scaleType="centerCrop"
                                    app:tint="?attr/FG_color"
                                    tools:ignore="ContentDescription,TooDeepLayout" />

                                <TextView
                                    android:id="@+id/watchSub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text=""
                                    android:singleLine="true"
                                    android:textColor="?attr/FG_color"
                                    android:fontFamily="@font/p"
                                    android:textSize="18sp"
                                    android:layout_marginHorizontal="4dp"
                                    tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            app:cardCornerRadius="5dp"
                            android:layout_gravity="center_horizontal"
                            app:cardBackgroundColor="?attr/SidebarFocus"
                            android:elevation="0dp"
                            android:layout_marginStart="5dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:paddingHorizontal="5dp"
                                android:gravity="center"
                                android:layout_gravity="center"
                                android:orientation="horizontal"
                                tools:ignore="UseCompoundDrawables">


                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_dub"
                                    app:tint="?attr/FG_color"
                                    tools:ignore="ContentDescription" />

                                <TextView
                                    android:id="@+id/watchDub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text=""
                                    android:singleLine="true"
                                    android:textColor="?attr/FG_color"
                                    android:fontFamily="@font/p"
                                    android:textSize="18sp"
                                    android:layout_marginHorizontal="4dp"
                                    tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    />

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@android:color/darker_gray"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:layout_marginHorizontal="25dp"
                            />




                        <TextView
                            android:id="@+id/watchType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Tv"
                            android:singleLine="true"
                            android:textColor="?attr/FG_color"
                            android:textSize="18sp"
                            android:fontFamily="@font/n"
                            android:alpha="0.7"
                            tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@android:color/darker_gray"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:layout_marginHorizontal="25dp"
                            />



                        <TextView
                            android:id="@+id/watchRuntime"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="bottom"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:layout_marginStart="9dp"
                            android:text=""
                            android:singleLine="false"
                            android:textColor="?attr/FG_color"
                            android:textSize="18sp"
                            android:fontFamily="@font/n"
                            android:alpha="0.7"
                            tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                            android:gravity="center"/>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@android:color/darker_gray"
                            android:textSize="20sp"
                            android:gravity="center"
                            android:layout_gravity="center"
                            android:layout_marginHorizontal="25dp"
                            />



                        <TextView
                            android:id="@+id/watchYear"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="bottom"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text=""
                            android:singleLine="false"
                            android:textColor="?attr/FG_color"
                            android:textSize="18sp"
                            android:fontFamily="@font/n"
                            tools:ignore="HardcodedText,SmallSp,Suspicious0dp"
                            android:gravity="center"
                            android:alpha="0.7"
                            android:layout_marginStart="9dp"/>




                    </LinearLayout>

                    <TextView
                        android:id="@+id/watchOverview"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-condensed"
                        android:text=""
                        android:layout_marginBottom="10dp"
                        android:ellipsize="end"
                        android:maxLines="6"
                        android:layout_marginTop="20dp"
                        android:textColor="?FG_color"
                        android:textSize="15sp"
                        tools:ignore="NestedWeights,SmallSp" />


                    <LinearLayout
                        android:id="@+id/favoriteButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_gravity="bottom"
                        android:background="@drawable/watch_button"
                        android:focusableInTouchMode="true"
                        android:focusable="true"
                        android:clickable="true"
                        android:paddingHorizontal="14dp"
                        android:elevation="2dp" >



                        <ImageButton
                            android:id="@+id/favoriteButtonImg"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:src="@drawable/ic_addfave"
                            app:tint="?attr/FG_color"
                            android:background="@android:color/transparent"
                            android:textColor="?attr/FG_color"
                            android:textAllCaps="false"
                            android:tooltipText="Add to Favorites"
                            tools:ignore="UnusedAttribute" />

                        <TextView
                            android:id="@+id/favoriteButtonText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add to Fav"
                            android:textSize="15sp"
                            android:fontFamily="@font/o"
                            android:textColor="?attr/FG_color"
                            android:textStyle="bold"
                            tools:ignore="HardcodedText" />

                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>



        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/SeasonTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Watch more seasons of this anime"
                android:textColor="?attr/FG_color"
                android:paddingHorizontal="5dp"
                android:textSize="23sp"
                android:textStyle="bold"
                android:fontFamily="@font/n"
                tools:ignore="HardcodedText" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:scrollbars="none"
                tools:ignore="SpeakableTextPresentCheck">

                <LinearLayout
                    android:id="@+id/anime_season_selector_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="5dp" />
            </HorizontalScrollView>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="List of episodes ("
                    android:textColor="?attr/FG_color"
                    android:paddingStart="5dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="serif-monospace"
                    tools:ignore="HardcodedText,RtlSymmetry" />
                <TextView
                    android:id="@+id/selected_seasonShow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="?attr/AccentColor"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/e"
                    tools:ignore="HardcodedText" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=")"
                        android:textColor="?attr/FG_color"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/e"
                        tools:ignore="HardcodedText" />
            </LinearLayout>


            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:ignore="SpeakableTextPresentCheck">

                <LinearLayout
                    android:id="@+id/anime_episodes_selector_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="5dp" />
            </HorizontalScrollView>




        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Recommended  Animes"
            android:fontFamily="@font/n"
            android:textSize="25sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:textColor="?attr/FG_color"
            tools:ignore="HardcodedText" />


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/animeWatchRecommendation"
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:padding="10dp"
            android:scrollbars="none"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:descendantFocusability="afterDescendants"
            android:nestedScrollingEnabled="false"
            tools:ignore="RtlSymmetry" />



    </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <include layout="@layout/laod_animation"/>

</androidx.constraintlayout.widget.ConstraintLayout>