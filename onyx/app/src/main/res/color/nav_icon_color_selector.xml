<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state -->
    <item android:color="?attr/FG_color" android:state_focused="true"/>
    <!-- Pressed (optional) -->
    <item android:color="?attr/AccentColor" android:state_selected="true"/>
    <!-- Default -->
    <item android:color="@android:color/darker_gray"/>
</selector>


