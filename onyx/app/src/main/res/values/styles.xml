<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom Dialog Theme -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:textColorPrimary">?attr/FG_color</item>
        <item name="android:textColorSecondary">#CCCCCC</item>
        <item name="colorPrimary">#33B5E5</item>
        <item name="colorPrimaryDark">#2A9BC4</item>
        <item name="colorAccent">?attr/AccentColor</item>
    </style>

    <style name="KeyboardKey">
        <item name="android:layout_width">35dp</item>
        <item name="android:layout_height">35dp</item>
        <item name="android:layout_margin">0.5dp</item>
        <item name="android:background">@drawable/filter_button</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">?attr/AccentColor</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="KeyboardKeySpecial">
        <item name="android:layout_width">70dp</item>
        <item name="android:layout_height">35dp</item>
        <item name="android:textSize">17sp</item>
        <item name="android:background">@drawable/filter_button</item>
        <item name="android:textColor">?attr/FG_color</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>

    <style name="KeyboardKeySpace">
        <item name="android:layout_width">130dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/FG_color</item>
        <item name="android:background">@drawable/filter_button</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
    </style>


</resources>
