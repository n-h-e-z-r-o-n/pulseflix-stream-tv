<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle" >

            <gradient
                android:type="linear"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="900dp"
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:endColor="?attr/AccentColor"
                />

            <stroke android:width="0dp" android:color="?attr/AccentColor" />
        </shape>
    </item>

    <item android:state_selected="true">
        <shape android:shape="rectangle" android:alpha="0.2">

            <gradient
                android:type="linear"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="900dp"
                android:angle="270"
                android:startColor="@android:color/transparent"
                android:endColor="#90E5E4E2"
                />

            <stroke android:width="0dp" android:color="?attr/AccentColor" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle"  android:alpha="0.2">

            <gradient
                android:type="linear"
                android:centerX="50%"
                android:centerY="80%"
                android:angle="270"
                android:gradientRadius="400dp"
                android:startColor="@android:color/transparent"
                android:endColor="@android:color/transparent"
                />
            <stroke android:width="0dp" android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>


