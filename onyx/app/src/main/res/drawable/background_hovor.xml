<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <gradient
                android:type="linear"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="80dp"
                android:startColor="@android:color/transparent"
                android:endColor="?attr/AccentColor"
                />

        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="7dp" />
            <gradient
                android:type="linear"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="80dp"
                android:startColor="@android:color/transparent"
                android:endColor="@android:color/darker_gray"
                />

            <stroke android:width="0dp" android:color="?attr/AccentColor" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle"  android:alpha="0.2">
            <corners android:radius="7dp" />
            <stroke android:width="1dp" android:color="?attr/transparentEffect" />
        </shape>
    </item>
</selector>


