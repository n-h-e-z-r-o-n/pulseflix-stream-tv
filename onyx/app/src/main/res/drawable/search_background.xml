<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <gradient
                android:type="linear"
                android:angle="-90"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="900dp"
                android:startColor="@android:color/transparent"
                android:endColor="?attr/AccentColor"
                />

            <stroke android:width="0dp" android:color="?attr/AccentColor" />
        </shape>
    </item>
    <item>
    <shape android:shape="rectangle">

        <gradient
            android:type="linear"
            android:angle="-90"
            android:centerX="50%"
            android:centerY="50%"
            android:gradientRadius="900dp"
            android:startColor="@android:color/transparent"
            android:endColor="@android:color/transparent"
            />

        <stroke
            android:width="0dp"
            android:color="?attr/BG_color_up"  />
    </shape>
</item>
</selector>