{
  "manifest_version": 2,
  "author": "Ghostery",
  "name": "__MSG_manifest_name__",
  "short_name": "Ghostery",
  "default_locale": "en",
  "description": "__MSG_manifest_short_description__",
  "permissions": [
    "alarms",
    "cookies",
    "storage",
    "scripting",
    "tabs",
    "activeTab",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "unlimitedStorage",
    "http://*/*",
    "https://*/*",
    "ws://*/*",
    "wss://*/*"
  ],
  "icons": {
    "32": "icons/icon.svg",
    "64": "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "browser_action": {
    "default_icon": {
      "32": "icons/icon.svg",
      "64": "icons/icon.svg",
      "128": "icons/icon.svg"
    },
    "default_area": "navbar",
    "default_title": "Ghostery",
    "default_popup": "pages/panel/index.html"
  },
  "options_ui": {
    "page": "pages/settings/index.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": [
      "background/index.js"
    ],
    "type": "module",
    "persistent": false
  },
  "content_scripts": [
    {
      "js": [
        "content_scripts/adblocker/index.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_start",
      "match_about_blank": true,
      "all_frames": true
    },
    {
      "js": [
        "content_scripts/autoconsent.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "js": [
        "content_scripts/notifications.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "content_scripts/whotracksme/reporting.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "run_at": "document_start"
    },
    {
      "js": [
        "content_scripts/youtube.js"
      ],
      "matches": [
        "*://www.youtube.com/*"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    "pages/trackers-preview/index.html",
    "pages/element-picker/index.html",
    "pages/notifications/youtube.html",
    "pages/notifications/pause-assistant.html",
    "pages/notifications/pause-resume.html",
    "pages/notifications/review.html",
    "pages/notifications/whats-new.html",
    "pages/redirect-protection/index.html",
    "rule_resources/redirects/1x1.gif",
    "rule_resources/redirects/2x2.png",
    "rule_resources/redirects/32x32.png",
    "rule_resources/redirects/3x2.png",
    "rule_resources/redirects/MIME_TYPE_STUB.flv",
    "rule_resources/redirects/MIME_TYPE_STUB.gif",
    "rule_resources/redirects/MIME_TYPE_STUB.html",
    "rule_resources/redirects/MIME_TYPE_STUB.ico",
    "rule_resources/redirects/MIME_TYPE_STUB.jpg",
    "rule_resources/redirects/MIME_TYPE_STUB.js",
    "rule_resources/redirects/MIME_TYPE_STUB.json",
    "rule_resources/redirects/MIME_TYPE_STUB.mp3",
    "rule_resources/redirects/MIME_TYPE_STUB.mp4",
    "rule_resources/redirects/MIME_TYPE_STUB.pdf",
    "rule_resources/redirects/MIME_TYPE_STUB.png",
    "rule_resources/redirects/MIME_TYPE_STUB.svg",
    "rule_resources/redirects/MIME_TYPE_STUB.txt",
    "rule_resources/redirects/MIME_TYPE_STUB.wav",
    "rule_resources/redirects/MIME_TYPE_STUB.webm",
    "rule_resources/redirects/MIME_TYPE_STUB.webp",
    "rule_resources/redirects/MIME_TYPE_STUB.wmv",
    "rule_resources/redirects/amazon_ads.js",
    "rule_resources/redirects/amazon_apstag.js",
    "rule_resources/redirects/ampproject_v0.js",
    "rule_resources/redirects/chartbeat.js",
    "rule_resources/redirects/click2load.html",
    "rule_resources/redirects/doubleclick_instream_ad_status.js",
    "rule_resources/redirects/empty",
    "rule_resources/redirects/fingerprint2.js",
    "rule_resources/redirects/fingerprint3.js",
    "rule_resources/redirects/google-analytics_analytics.js",
    "rule_resources/redirects/google-analytics_cx_api.js",
    "rule_resources/redirects/google-analytics_ga.js",
    "rule_resources/redirects/google-analytics_inpage_linkid.js",
    "rule_resources/redirects/google-ima.js",
    "rule_resources/redirects/googlesyndication_adsbygoogle.js",
    "rule_resources/redirects/googletagservices_gpt.js",
    "rule_resources/redirects/hd-main.js",
    "rule_resources/redirects/nobab.js",
    "rule_resources/redirects/nobab2.js",
    "rule_resources/redirects/noeval-silent.js",
    "rule_resources/redirects/noeval.js",
    "rule_resources/redirects/nofab.js",
    "rule_resources/redirects/noop-0.1s.mp3",
    "rule_resources/redirects/noop-0.5s.mp3",
    "rule_resources/redirects/noop-1s.mp4",
    "rule_resources/redirects/noop-vast2.xml",
    "rule_resources/redirects/noop-vast3.xml",
    "rule_resources/redirects/noop-vast4.xml",
    "rule_resources/redirects/noop-vmap1.xml",
    "rule_resources/redirects/noop.css",
    "rule_resources/redirects/noop.html",
    "rule_resources/redirects/noop.js",
    "rule_resources/redirects/noop.json",
    "rule_resources/redirects/noop.txt",
    "rule_resources/redirects/outbrain-widget.js",
    "rule_resources/redirects/popads-dummy.js",
    "rule_resources/redirects/popads.js",
    "rule_resources/redirects/prebid-ads.js",
    "rule_resources/redirects/scorecardresearch_beacon.js",
    "rule_resources/redirects/sensors-analytics.js"
  ],
  "content_security_policy": "script-src 'self'",
  "browser_specific_settings": {
    "gecko_android": {},
    "gecko": {
      "id": "firefox@ghostery.com",
      "strict_min_version": "115.0"
    }
  },
  "version": "10.5.25"
}